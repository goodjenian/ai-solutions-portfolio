# OpenAI
OPENAI_API_KEY=sk-...

# Serper (web search)
SERPER_API_KEY=...

# Tavily (web search)
TAVILY_API_KEY=...

# Your Gmail address (used to filter out your own sent messages)
MY_EMAIL=you@gmail.com

# SECURITY NOTICE:
# - Keep credentials.json (Gmail OAuth token) out of version control (.gitignore already covers it)
# - Rotate OPENAI_API_KEY if accidentally exposed
# - Email content is sent to OpenAI for processing — do not use with confidential/privileged emails
# - This tool reads your inbox and creates draft replies on your behalf
