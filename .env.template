# ================================================================
# GoodySEO AI Products — Master Environment Configuration
# ================================================================
# 1. Copy this file:  cp .env.template .env
# 2. Fill in every value below
# 3. NEVER commit .env to version control (it's in .gitignore)
# ================================================================


# ----------------------------------------------------------------
# SECURITY — API Keys for your clients/users
# ----------------------------------------------------------------
# Generate each key with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Add one key per client separated by commas (no spaces)
# Example: GOODYSEO_API_KEYS=key-internal-goodyseo,key-client-xyz,key-client-abc
GOODYSEO_API_KEYS=


# ----------------------------------------------------------------
# OPENAI
# ----------------------------------------------------------------
# Get at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL_NAME=gpt-4o


# ----------------------------------------------------------------
# SERPER — Web Search (used by StrategyAI, ContentFlow, InboxAI)
# ----------------------------------------------------------------
# Free tier: 2500 queries/month — https://serper.dev/
SERPER_API_KEY=


# ----------------------------------------------------------------
# TAVILY — Web Search (used by InboxAI)
# ----------------------------------------------------------------
# Free tier available — https://app.tavily.com/
TAVILY_API_KEY=


# ----------------------------------------------------------------
# BROWSERLESS — Cloud Browser (used by ContentFlow + TradAI)
# ----------------------------------------------------------------
# Free tier: 6h/month — https://www.browserless.io/
BROWSERLESS_API_KEY=


# ----------------------------------------------------------------
# INBOXAI — Gmail (email_auto_responder_flow)
# ----------------------------------------------------------------
# Your Gmail address (used to exclude your own sent messages)
MY_EMAIL=
# Note: credentials.json and token.json must be in ./secrets/
# See DEPLOY.md Step 4 for how to generate them


# ----------------------------------------------------------------
# MEETINGOPS — Slack (meeting_assistant_flow)
# ----------------------------------------------------------------
# Create a Bot at: https://api.slack.com/apps → "OAuth & Permissions"
# Scopes needed: chat:write, channels:read
SLACK_TOKEN=
SLACK_CHANNEL_ID=

# Trello — https://trello.com/app-key
TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_BOARD_ID=
TRELLO_LIST_ID=


# ----------------------------------------------------------------
# TRADAI — SEC EDGAR (stock_analysis)
# ----------------------------------------------------------------
# Free plan: https://sec-api.io/
SEC_API_API_KEY=

# REQUIRED by SEC.gov: your app name + contact email
# Format: "AppName contact@yourdomain.com"
SEC_API_USER_AGENT=GoodySEO contact@goodyseo.com


# ----------------------------------------------------------------
# OPTIONAL — Redis (for distributed rate limiting across instances)
# ----------------------------------------------------------------
# Leave blank to use in-memory rate limiting (fine for single server)
# REDIS_URL=redis://localhost:6379/0
